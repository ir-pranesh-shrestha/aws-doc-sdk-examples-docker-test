# syntax=docker/dockerfile:1
# Variation 10: Multi-project build (several services)
# Complexity: HIGH
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY ./dotnetv3/SES/ ./SES/
COPY ./dotnetv3/S3/ ./S3/
COPY ./dotnetv3/IAM/ ./IAM/
RUN find ./S3 -name "*.csproj" && find ./IAM -name "*.csproj"
RUN dotnet restore ./SES/Actions/SESActions.csproj && \
    dotnet restore ./S3/Actions/S3Actions.csproj && \
    dotnet restore ./IAM/Actions/IAMActions.csproj
RUN dotnet publish ./SES/Actions/SESActions.csproj -c Release -o /app/ses && \
    dotnet publish ./S3/Actions/S3Actions.csproj  -c Release -o /app/s3  && \
    dotnet publish ./IAM/Actions/IAMActions.csproj -c Release -o /app/iam
# ---- Runtime ----
FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/ses ./ses
COPY --from=build /app/s3  ./s3
COPY --from=build /app/iam ./iam
CMD ["bash"]
