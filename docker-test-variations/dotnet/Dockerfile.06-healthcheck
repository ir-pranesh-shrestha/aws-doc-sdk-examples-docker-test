# syntax=docker/dockerfile:1
# Variation 06: HEALTHCHECK included
# Complexity: MEDIUM

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build

WORKDIR /src

COPY ./dotnetv3/SES/Actions/SESActions.csproj ./SES/Actions/

RUN cd SES && dotnet restore Actions/SESActions.csproj

COPY ./dotnetv3/SES/ ./SES/

RUN cd SES && dotnet publish Actions/SESActions.csproj -c Release -o /app/publish

# ---- Runtime ----
FROM mcr.microsoft.com/dotnet/aspnet:8.0

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build /app/publish .

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:80/health || exit 1

ENTRYPOINT ["dotnet", "SESActions.dll"]
