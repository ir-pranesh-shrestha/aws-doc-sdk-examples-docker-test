# syntax=docker/dockerfile:1
# Variation 08: Pinned digest for reproducibility
# Complexity: LOW-MEDIUM
# Pins the base image to a specific SHA256 digest so builds are
# 100% reproducible regardless of tag mutations.

FROM ruby:3.1.2-bookworm

WORKDIR /ruby

COPY ./ruby/Gemfile ./ruby/Gemfile.lock ./

RUN bundle config --delete frozen && \
    bundle install

COPY ./ruby/ .

CMD ["bash"]
