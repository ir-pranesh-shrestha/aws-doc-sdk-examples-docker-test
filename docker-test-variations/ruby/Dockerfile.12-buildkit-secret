# syntax=docker/dockerfile:1
# Variation 12: Build-time secret injection (SSH / token)
# Complexity: HIGH
# Uses Docker BuildKit --mount=type=secret to pass credentials at
# build time without baking them into any image layer.
# Build with:
#   DOCKER_BUILDKIT=1 docker build --secret id=github_token,env=GITHUB_TOKEN ...

FROM ruby:3.1.2-bullseye

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        openssh-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /ruby

COPY ./ruby/Gemfile ./ruby/Gemfile.lock ./

# Mount the secret only during this RUN layer — never persisted in image
RUN --mount=type=secret,id=github_token \
    export BUNDLE_GITHUB__COM="$(cat /run/secrets/github_token):x-oauth-basic" && \
    bundle config --delete frozen && \
    bundle install --jobs 4

COPY ./ruby/ .

CMD ["bash"]
