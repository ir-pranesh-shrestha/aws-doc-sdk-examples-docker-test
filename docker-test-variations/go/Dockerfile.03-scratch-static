# syntax=docker/dockerfile:1
# Variation 03: Scratch (absolute minimal static binary)
# Complexity: HIGH
# Final image is FROM scratch — only the statically linked binary + TLS certs.

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN cd dynamodb && \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -a -installsuffix cgo -ldflags="-s -w" -o /dynamodb-static ./cmd/

# ---- Scratch ----
FROM scratch

COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /dynamodb-static /dynamodb-static

ENTRYPOINT ["/dynamodb-static"]
