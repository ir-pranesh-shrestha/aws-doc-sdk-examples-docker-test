# syntax=docker/dockerfile:1
# Variation 02: Multi-Stage Build (compiled binary + Alpine runtime)
# Complexity: MEDIUM
# Builder compiles the dynamodb example; runtime only carries the binary.

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN cd dynamodb && \
    CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /dynamodb-app ./cmd/

# ---- Runtime ----
FROM alpine:3.18 AS runtime

RUN apk add --no-cache ca-certificates

COPY --from=builder /dynamodb-app /dynamodb-app

CMD ["/dynamodb-app"]
