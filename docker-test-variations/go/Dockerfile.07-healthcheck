# syntax=docker/dockerfile:1
# Variation 07: HEALTHCHECK included
# Complexity: MEDIUM

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN cd dynamodb && \
    CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /dynamodb-app ./cmd/

FROM alpine:3.18

RUN apk add --no-cache ca-certificates curl

COPY --from=builder /dynamodb-app /dynamodb-app

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["/dynamodb-app"]
