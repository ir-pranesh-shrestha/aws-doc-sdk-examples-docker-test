# syntax=docker/dockerfile:1
# Variation 14: Multi-stage + non-root + read-only FS
# Complexity: HIGH

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd dynamodb && \
    CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /dynamodb-app ./cmd/

FROM alpine:3.18

RUN apk add --no-cache ca-certificates \
    && addgroup -S gogroup \
    && adduser -S -G gogroup gouser

COPY --from=builder /dynamodb-app /dynamodb-app

USER gouser

# Run with: docker run --read-only --tmpfs /tmp ...
VOLUME ["/tmp"]

ENTRYPOINT ["/dynamodb-app"]
