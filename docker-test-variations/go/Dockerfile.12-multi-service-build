# syntax=docker/dockerfile:1
# Variation 12: Multi-service build (multiple packages compiled)
# Complexity: HIGH
# Compiles several service packages in one image for integration testing.

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd dynamodb && CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/dynamodb-app ./cmd/ && \
    cd ../s3 && CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/s3-app ./cmd/ && \
    cd ../iam && CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/iam-app ./cmd/

FROM alpine:3.18

RUN apk add --no-cache ca-certificates

COPY --from=builder /bin/dynamodb-app /bin/dynamodb-app
COPY --from=builder /bin/s3-app /bin/s3-app
COPY --from=builder /bin/iam-app /bin/iam-app

CMD ["bash"]
