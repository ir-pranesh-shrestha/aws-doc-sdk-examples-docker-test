# syntax=docker/dockerfile:1
# Variation 05: Non-root user
# Complexity: MEDIUM

FROM golang:1.21 AS builder

WORKDIR /build

COPY ./gov2/ .

RUN cd dynamodb && \
    CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /dynamodb-app ./cmd/

# ---- Runtime ----
FROM alpine:3.18

RUN apk add --no-cache ca-certificates \
    && addgroup -S gogroup \
    && adduser -S -G gogroup gouser

COPY --from=builder /dynamodb-app /dynamodb-app

USER gouser

ENTRYPOINT ["/dynamodb-app"]
