# syntax=docker/dockerfile:1
# Variation 12: Layered JAR (simulated layers for non-Spring-Boot jar)
# Complexity: HIGH
FROM maven:3.9-eclipse-temurin-17 AS builder
WORKDIR /build
COPY ./javav2/example_code/cloudwatch/ .
RUN mvn package -Dmaven.test.skip -Dcheckstyle.skip=true -q
# Separate deps from app jar for layer caching
RUN mkdir -p /app/extracted/dependencies /app/extracted/application && \
    mvn dependency:copy-dependencies -DoutputDirectory=/app/extracted/dependencies -q && \
    cp target/*.jar /app/extracted/application/app.jar
# ---- Runtime ----
FROM eclipse-temurin:17-jre-jammy
WORKDIR /app
COPY --from=builder /app/extracted/dependencies/ ./libs/
COPY --from=builder /app/extracted/application/app.jar ./
EXPOSE 8080
ENTRYPOINT ["java", "-cp", "app.jar:libs/*", "com.example.cloudwatch.CloudWatch"]
