# syntax=docker/dockerfile:1
# Variation 13: Gradle build (alternative to Maven)
# Complexity: MEDIUM
FROM gradle:8.5-jdk17 AS builder
WORKDIR /build
COPY ./javav2/ .
RUN cd example_code/cloudwatch && \
    gradle build -x test --no-daemon -q

FROM eclipse-temurin:17-jre-jammy
WORKDIR /app
COPY --from=builder /build/example_code/cloudwatch/build/libs/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
