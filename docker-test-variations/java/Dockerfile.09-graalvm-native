# syntax=docker/dockerfile:1
# Variation 09: GraalVM Native Image
# Complexity: HIGHEST
FROM ghcr.io/graalvm/native-image-community:17 AS native-builder
WORKDIR /build
COPY ./javav2/example_code/cloudwatch/ .
RUN microdnf install -y maven && \
    mvn package dependency:copy-dependencies -DoutputDirectory=target/deps \
        -Dmaven.test.skip -Dcheckstyle.skip -q && \
    native-image -cp "target/*.jar:target/deps/*" \
        --no-fallback \
        -o cloudwatch-native \
        com.example.cloudwatch.PutMetricData
# ---- Minimal runtime ----
FROM debian:bookworm-slim
RUN groupadd -r javagroup && useradd -r -g javagroup javauser
COPY --from=native-builder /build/cloudwatch-native /cloudwatch-native
USER javauser
EXPOSE 8080
ENTRYPOINT ["/cloudwatch-native"]# syntax=docker/dockerfile:1
